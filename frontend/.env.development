# 开发环境配置（fallback）
# 通过项目根脚本启动时（./start-dev.sh），实际配置由 console/.env 统一注入，此文件不生效。
# 仅在单独 cd frontend && pnpm dev 时作为默认值使用。
# 实际端口请以 console/.env 中的 API_PORT / VITE_DEV_PORT 为准。

VITE_API_BASE_URL=http://localhost:8000
VITE_DEV_PORT=5173
VITE_DEV_HOST=0.0.0.0
VITE_DEV_OPEN=true
VITE_DEV_STRICT_PORT=false
VITE_APP_TITLE=IngenuityLab Console
VITE_API_TIMEOUT=30000
