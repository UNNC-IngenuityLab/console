# ============================================================================
# IngenuityLab Admin Frontend - 环境配置
# ============================================================================

# ----------------------------------------------------------------------------
# 后端 API 地址
# ----------------------------------------------------------------------------
# 完整的 API 地址，包含协议、主机和端口
# 根据后端实际运行的端口修改此配置

# 示例配置（根据你的后端端口选择）：
# - 后端运行在 8000 端口: http://localhost:8000
# - 后端运行在 8080 端口: http://localhost:8080
# - 后端运行在 3000 端口: http://localhost:3000
# - 后端运行在 5000 端口: http://localhost:5000
# - 使用远程服务器: http://your-server.com:8000

VITE_API_BASE_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# 开发服务器配置
# ----------------------------------------------------------------------------
# 开发服务器端口（修改你想要的前端端口）
VITE_DEV_PORT=5173

# 开发服务器监听地址（0.0.0.0 允许外部访问，localhost 仅本机访问）
VITE_DEV_HOST=0.0.0.0

# 启动时是否自动打开浏览器
VITE_DEV_OPEN=true

# 是否严格使用指定端口（端口被占用时不自动尝试其他端口）
VITE_DEV_STRICT_PORT=false

# ----------------------------------------------------------------------------
# 其他配置
# ----------------------------------------------------------------------------
# 应用标题（可选）
VITE_APP_TITLE=IngenuityLab Console

# API 请求超时时间（毫秒）
VITE_API_TIMEOUT=30000
