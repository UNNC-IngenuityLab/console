# ============================================================================
# IngenuityLab Console Frontend - 环境配置说明
# ============================================================================
#
# 【推荐】使用 console/.env 统一管理前后端配置，并通过 ./start-dev.sh 启动。
#         start-dev.sh 会自动将 VITE_* 变量注入为 .env.local，无需手动维护此文件。
#
# 【单独启动前端】若需单独 cd frontend && pnpm dev，请复制此文件为 .env.local：
#   cp .env.example .env.local
# ============================================================================

# 后端 API 地址（端口需与 console/.env 中 API_PORT 一致）
VITE_API_BASE_URL=http://localhost:8000

# 开发服务器端口
VITE_DEV_PORT=5173

# 开发服务器监听地址（0.0.0.0 允许外部访问，localhost 仅本机）
VITE_DEV_HOST=0.0.0.0

# 启动时是否自动打开浏览器
VITE_DEV_OPEN=true

# 端口被占用时是否报错退出（false = 自动换端口）
VITE_DEV_STRICT_PORT=false

# 应用标题
VITE_APP_TITLE=IngenuityLab Console

# API 请求超时时间（毫秒）
VITE_API_TIMEOUT=30000
