# ============================================================================
# IngenuityLab Console Frontend - 生产环境配置示例
# 复制此文件为 .env.production 并填写实际部署地址
# ============================================================================

# 后端 API 地址（填写实际服务器地址）
VITE_API_BASE_URL=http://your-server.com:8000

# 同域部署时（Nginx 反代 /api → 后端），改用相对路径：
# VITE_API_BASE_URL=/api

# 应用标题
VITE_APP_TITLE=IngenuityLab Console

# API 请求超时时间（毫秒）
VITE_API_TIMEOUT=30000
