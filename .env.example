# ============================================================================
# IngenuityLab Console - 统一开发环境配置示例
# 复制此文件为 .env 并填写实际值
# 此文件同时配置后端（FastAPI）和前端（Vite）
# ============================================================================

# ----------------------------------------------------------------------------
# 数据库配置（后端必填）
# ----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ingenuity_lab
DB_USER=root
DB_PASSWORD=your_database_password_here

# ----------------------------------------------------------------------------
# JWT 认证（后端必填）
# 生成命令: python -c "import secrets; print(secrets.token_hex(32))"
# ----------------------------------------------------------------------------
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ----------------------------------------------------------------------------
# API 服务器配置（后端）
# ----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# 允许的跨域来源，与前端 VITE_DEV_PORT 保持一致
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ----------------------------------------------------------------------------
# 前端配置（Vite）
# VITE_API_BASE_URL 中的端口需与 API_PORT 保持一致
# ----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000
VITE_DEV_PORT=5173
VITE_DEV_HOST=0.0.0.0
VITE_DEV_OPEN=true
VITE_DEV_STRICT_PORT=false
VITE_APP_TITLE=IngenuityLab Console
VITE_API_TIMEOUT=30000

# ----------------------------------------------------------------------------
# 运行环境
# ----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
