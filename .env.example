# ============================================================================
# IngenuityLab Console - 环境配置
# ============================================================================

# ----------------------------------------------------------------------------
# 数据库配置
# ----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ingenuity_lab
DB_USER=root
DB_PASSWORD=your_password_here

# ----------------------------------------------------------------------------
# JWT 配置
# ----------------------------------------------------------------------------
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ----------------------------------------------------------------------------
# API 服务配置
# ----------------------------------------------------------------------------
# 服务监听地址 (0.0.0.0 表示监听所有网卡)
API_HOST=0.0.0.0
# 服务端口 (可根据需要修改，如: 8000, 8080, 3000, 5000 等)
API_PORT=8000

# ----------------------------------------------------------------------------
# CORS 跨域配置
# ----------------------------------------------------------------------------
# 允许的前端地址（需要包含端口），多个地址用逗号分隔
# 示例: http://localhost:5173,http://localhost:3000,http://localhost:8080
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ----------------------------------------------------------------------------
# 环境配置
# ----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
